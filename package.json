{
  "name": "mexc-sdk",
  "version": "1.1.4",
  "description": "Минималистичный SDK для работы с MEXC API v3",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node --env-file=.env examples/demo.js",
    "order": "node --env-file=.env examples/get_order.js",
    "futures": "node --env-file=.env examples/futures.js",
    "ws": "node --env-file=.env examples/ws.js",
    "serve": "node --env-file=.env scripts/serve.js",
    "dev": "node scripts/serve.js & node --env-file=.env examples/ws.js",
    "inject-version": "node scripts/inject-version.js",
    "prebuild": "npm run inject-version"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
